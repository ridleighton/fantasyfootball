# Supabase — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_APIKEY=your-anon-public-key
SUPABASE_SECRET=your-service-role-secret-key

# Neon Postgres (existing — copy from Netlify env vars)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# api-sports.io (already set in Netlify as SPORTSIO_APIKEY)
SPORTSIO_APIKEY=your-key
